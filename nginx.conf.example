# ─────────────────────────────────────────────────────────────────────────────
# BTCFaucet — nginx endurecido contra spoofing de IP.
#
# Problema: o app lê o IP do cliente de CF-Connecting-IP / X-Forwarded-For.
# Se o nginx aceitar conexões de qualquer origem, um atacante que bata direto
# no IP do origin pode forjar esses headers e burlar TODOS os cooldowns por
# IP/subnet (cada request "vem" de um IP novo).
#
# Defesa:
#   1) `allow` apenas os ranges da Cloudflare; `deny all` no resto.
#   2) real_ip: confia em CF-Connecting-IP SÓ quando a conexão vem da CF.
#   3) Sobrescreve o header repassado ao backend com o IP real ($remote_addr),
#      de modo que qualquer valor forjado pelo cliente é descartado.
#
# Mantenha os ranges atualizados: https://www.cloudflare.com/ips/
# ─────────────────────────────────────────────────────────────────────────────

# Ranges oficiais da Cloudflare (IPv4)
set_real_ip_from 173.245.48.0/20;
set_real_ip_from 103.21.244.0/22;
set_real_ip_from 103.22.200.0/22;
set_real_ip_from 103.31.4.0/22;
set_real_ip_from 141.101.64.0/18;
set_real_ip_from 108.162.192.0/18;
set_real_ip_from 190.93.240.0/20;
set_real_ip_from 188.114.96.0/20;
set_real_ip_from 197.234.240.0/22;
set_real_ip_from 198.41.128.0/17;
set_real_ip_from 162.158.0.0/15;
set_real_ip_from 104.16.0.0/13;
set_real_ip_from 104.24.0.0/14;
set_real_ip_from 172.64.0.0/13;
set_real_ip_from 131.0.72.0/22;
# Cloudflare (IPv6)
set_real_ip_from 2400:cb00::/32;
set_real_ip_from 2606:4700::/32;
set_real_ip_from 2803:f800::/32;
set_real_ip_from 2405:b500::/32;
set_real_ip_from 2405:8100::/32;
set_real_ip_from 2a06:98c0::/29;
set_real_ip_from 2c0f:f248::/32;

real_ip_header CF-Connecting-IP;
real_ip_recursive on;

server {
    listen 80;
    server_name faucet.seudominio.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name faucet.seudominio.com;

    ssl_certificate     /etc/letsencrypt/live/faucet.seudominio.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/faucet.seudominio.com/privkey.pem;

    # 1) Só aceita tráfego vindo da Cloudflare. Bater direto no origin → 403.
    allow 173.245.48.0/20;
    allow 103.21.244.0/22;
    allow 103.22.200.0/22;
    allow 103.31.4.0/22;
    allow 141.101.64.0/18;
    allow 108.162.192.0/18;
    allow 190.93.240.0/20;
    allow 188.114.96.0/20;
    allow 197.234.240.0/22;
    allow 198.41.128.0/17;
    allow 162.158.0.0/15;
    allow 104.16.0.0/13;
    allow 104.24.0.0/14;
    allow 172.64.0.0/13;
    allow 131.0.72.0/22;
    allow 2400:cb00::/32;
    allow 2606:4700::/32;
    allow 2803:f800::/32;
    allow 2405:b500::/32;
    allow 2405:8100::/32;
    allow 2a06:98c0::/29;
    allow 2c0f:f248::/32;
    deny all;

    location / {
        proxy_pass         http://127.0.0.1:8420;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        # 3) Descarta qualquer valor forjado pelo cliente: repassa só o IP real
        #    resolvido pelo módulo real_ip (confiável porque veio da CF).
        proxy_set_header   CF-Connecting-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $remote_addr;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}
